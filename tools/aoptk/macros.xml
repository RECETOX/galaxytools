<macros>
    <token name="@TOOL_VERSION@">0.4.3</token>
    <token name="@VERSION_SUFFIX@">0</token>

    <xml name="requirements">
        <requirement type="package" version="@TOOL_VERSION@">aoptk</requirement>
        <requirement type="package" version="6.0.3">pyyaml</requirement>
    </xml>

    <xml name="email_credentials">
        <credentials name="email_credentials" 
                     label="Your e-mail address" 
                     version="1.0"
                     optional="true"
                     description="E-mail is required to follow NCBI/PubMed guidelines.">
            <variable name="email" inject_as_env="EMAIL" optional="true"/>
        </credentials>
    </xml>

    <xml name="ncbi_api_key">
        <credentials name="ncbi_api_key" 
                     label="Your NCBI API key" 
                     version="1.0"
                     optional="true"
                     description="Provide your NCBI API key for faster download of publications. https://support.nlm.nih.gov/kbArticle/?pn=KA-05317">
            <secret name="api_key" inject_as_env="NCBI_API_KEY" optional="true"/>
        </credentials>
    </xml>

    <xml name="search_term">
        <param argument="--search_term" type="text" value="" label="Your search term" help="Type your search term as you would in PMC, Europe PMC, or PubMed.">
            <sanitizer invalid_char="">
                <valid initial="string.letters,string.digits">
                    <add value="_" />
                    <add value=" " />
                    <add value="&apos;" />
                    <add value="&quot;" />
                    <add value="(" />
                    <add value=")" />
                    <add value="*" />
                    <add value="[" />
                    <add value="]" />
                    <add value="-" />
                    <add value=":" />
                    <add value="/" />
                    <add value="α" />
                    <add value="β" />
                    <add value="γ" />
                    <add value="δ" />
                    <add value="ε" />
                    <add value="ζ" />
                    <add value="η" />
                    <add value="θ" />
                    <add value="ι" />
                    <add value="κ" />
                    <add value="λ" />
                    <add value="μ" />
                    <add value="ν" />
                    <add value="ξ" />
                    <add value="ο" />
                    <add value="π" />
                    <add value="ρ" />
                    <add value="σ" />
                    <add value="τ" />
                    <add value="υ" />
                    <add value="φ" />
                    <add value="χ" />
                    <add value="ψ" />
                    <add value="ω" />
                    <add value="Α" />
                    <add value="Β" />
                    <add value="Γ" />
                    <add value="Δ" />
                    <add value="Ε" />
                    <add value="Ζ" />
                    <add value="Η" />
                    <add value="Θ" />
                    <add value="Ι" />
                    <add value="Κ" />
                    <add value="Λ" />
                    <add value="Μ" />
                    <add value="Ν" />
                    <add value="Ξ" />
                    <add value="Ο" />
                    <add value="Π" />
                    <add value="Ρ" />
                    <add value="Σ" />
                    <add value="Τ" />
                    <add value="Υ" />
                    <add value="Φ" />
                    <add value="Χ" />
                    <add value="Ψ" />
                    <add value="Ω" />
                </valid>
            </sanitizer>
            <validator type="regex">[0-9a-zA-Z_ ()*'"[\]\[\]\-:.\[\]α-ωΑ-Ω]*</validator>
        </param>
    </xml>

    <xml name="llm_models">
        <param name="llm_models" type="select" label="Select LLM" help="Select the LLM to analyze text.">
            <option value="gpt-oss-120b">GPT OSS 120B</option>
            <option value="qwen3.5">Qwen 3.5</option>
            <option value="deepseek-v3.2-thinking">DeepSeek v3.2</option>
        </param>
    </xml>

    <xml name="llm_models_images">
        <param name="llm_models_images" type="select" label="Select the LLM to analyze image data." help="Choose the LLM to use for image data processing.">
            <option value="qwen3.5">Qwen 3.5</option>
            <option value="redhatai-scout">RedHatAI Scout</option>
        </param>
    </xml>

    <xml name="prompt_specification">
        <param argument="--prompt_specification" type="text" value="" optional="true" label="Analysis specification" help="Prompt the LLM and specify what data to analyze (e.g., Only include data from HepG2 spheroids).">
            <sanitizer invalid_char="">
                <valid initial="string.letters,string.digits">
                    <add value="_" />
                    <add value=" " />
                    <add value="(" />
                    <add value=")" />
                    <add value="*" />
                    <add value="[" />
                    <add value="]" />
                    <add value="-" />
                    <add value=":" />
                    <add value="/" />
                    <add value="α" />
                    <add value="β" />
                    <add value="γ" />
                    <add value="δ" />
                    <add value="ε" />
                    <add value="ζ" />
                    <add value="η" />
                    <add value="θ" />
                    <add value="ι" />
                    <add value="κ" />
                    <add value="λ" />
                    <add value="μ" />
                    <add value="ν" />
                    <add value="ξ" />
                    <add value="ο" />
                    <add value="π" />
                    <add value="ρ" />
                    <add value="σ" />
                    <add value="τ" />
                    <add value="υ" />
                    <add value="φ" />
                    <add value="χ" />
                    <add value="ψ" />
                    <add value="ω" />
                    <add value="Α" />
                    <add value="Β" />
                    <add value="Γ" />
                    <add value="Δ" />
                    <add value="Ε" />
                    <add value="Ζ" />
                    <add value="Η" />
                    <add value="Θ" />
                    <add value="Ι" />
                    <add value="Κ" />
                    <add value="Λ" />
                    <add value="Μ" />
                    <add value="Ν" />
                    <add value="Ξ" />
                    <add value="Ο" />
                    <add value="Π" />
                    <add value="Ρ" />
                    <add value="Σ" />
                    <add value="Τ" />
                    <add value="Υ" />
                    <add value="Φ" />
                    <add value="Χ" />
                    <add value="Ψ" />
                    <add value="Ω" />
                </valid>
            </sanitizer>
            <validator type="regex">[0-9a-zA-Z_ ()*'"[\]\[\]\-:.\[\]α-ωΑ-Ω]*</validator>
        </param>
    </xml>

    <xml name="effect">
        <param argument="effect" type="text" value="" label="Effect to search" help="Specify the effect you want to search for (e.g., liver fibrosis, gap junction intracellular communication).">
            <validator type="regex">[0-9a-zA-Z]+</validator>
        </param>
    </xml>

    <xml name="relationship_type">
        <param name="relationship_type" type="select" label="Select relationship type" help="Choose the type of relationship to identify.">
            <option value="causative">Causative</option>
            <option value="inhibitive">Inhibitive</option>
        </param>
    </xml>
    
    <xml name="preprint_mode">
        <param name="preprint_mode" type="select" label="Preprint handling" help="Choose how preprints should be handled in the search results.">
            <option value="all" selected="true">Include preprints and non-preprints</option>
            <option value="exclude">Exclude preprints</option>
            <option value="only">Only include preprints</option>
        </param>
    </xml>

    <xml name="licensing">
        <param name="licensing" type="select" label="Licensing" help="Limit your search results to publications with specific Creative Commons (CC) licenses.">
            <option value="all" selected="true">No licensing specification</option>
            <option value="open-access">Open Access</option>
            <option value="CC0">CC0</option>
            <option value="CC-BY">CC-BY</option>
            <option value="CC-BY-SA">CC-BY-SA</option>
            <option value="CC-BY-ND">CC-BY-ND</option>
            <option value="CC-BY-NC">CC-BY-NC</option>
            <option value="CC-BY-NC-ND">CC-BY-NC-ND</option>
            <option value="CC-BY-NC-SA">CC-BY-NC-SA</option>
        </param>
    </xml>


<token name="@init_scores@">
from matchms.importing import load_from_msp, scores_from_json
from matchms import Scores
#if $scores.use_scores == "True"
scores = scores_from_json("$scores_in")
join_type = "$scores.join_type"
#else
scores = Scores(references=list(load_from_msp("$references")), queries=list(load_from_msp("$queries")), is_symmetric=False)
join_type = "left"
#end if
</token>

<token name="@init_logger@">
from matchms import set_matchms_logger_level
set_matchms_logger_level("WARNING")
</token>   
</macros>
