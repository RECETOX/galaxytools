    <requirements>
        <requirement type="package" version="@TOOL_VERSION@">sparqlwrapper</requirement>
    </requirements>
    <command detect_errors="exit_code"><![CDATA[
    python3 "${python_wrapper}"
    ]]></command>
    <configfiles>
        <configfile name="python_wrapper"><![CDATA[
from SPARQLWrapper import SPARQLWrapper, TSV, JSON, XML

sparql = SPARQLWrapper('$endpoint')
query = """
${query}
"""
sparql.setQuery(query)
sparql.setReturnFormat(TSV)
results = sparql.query().convert()
with open("output.tsv", "wb") as out_handle:
    out_handle.write(results)
]]></configfile>
    </configfiles>
    <inputs>
        <param argument="--endpoint" type="text" value="" label="address of the sparql endpoint to use" help="TODO"/>
        <param argument="--query" type="text" value="" label="sparql query to execute" help="TODO" area="true">
            <sanitizer invalid_char="">
                <valid initial="string.letters,string.digits">
                    <add value="_" />
                    <add value=" " />
                    <add value="&apos;" />
                    <add value="&quot;" />
                    <add value="(" />
                    <add value=")" />
                    <add value="*" />
                    <add value="[" />
                    <add value="]" />
                    <add value="{" />
                    <add value="}" />
                    <add value="-" />
                    <add value=":" />
                    <add value=";" />
                    <add value="." />
                    <add value="," />
                    <add value="/" />
                    <add value=">" />
                    <add value="&lt;" />
                    <add value="?" />
                    <add value="@" />
                    <add value="#" />
                    <add value="^" />
                    <add value="|" />
                </valid>
            </sanitizer>
        </param>
    </inputs>
    <outputs>
        <data name="output" format="tabular" from_work_dir="output.tsv" label="sparql query results in tabular format" />
    </outputs>
    <tests>
        <!-- Hint: You can use [ctrl+alt+t] after defining the inputs/outputs to auto-scaffold some basic test cases. -->
    </tests>
